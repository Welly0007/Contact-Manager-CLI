namespace Infrastructure.Persistence
{
	public class FileLock : IFileLock
	{
		private readonly string _filePath;

		public FileLock(string filePath)
		{
			_filePath = filePath;
		}

		public async Task ExecuteAsync(Func<FileStream, Task> action)
		{
			Directory.CreateDirectory(Path.GetDirectoryName(_filePath)!);

			const int maxAttempts = 3;               // ~ up to ~20-60s depending on delays
			var delay = TimeSpan.FromMilliseconds(50); // start small for responsiveness

			for (var attempt = 1; attempt <= maxAttempts; attempt++)
			{
				try
				{
					await using var stream = new FileStream(
						_filePath,
						FileMode.OpenOrCreate,
						FileAccess.ReadWrite,
						FileShare.None);

					// Optional: keep this ONLY if you want to simulate a long hold of the lock
					await Task.Delay(TimeSpan.FromSeconds(5));

					await action(stream);
					return;
				}
				catch (IOException) when (attempt < maxAttempts)
				{
					// Someone else holds the file. Wait and retry (queue behavior).
					await Task.Delay(delay);

					// Exponential backoff (caps at 1s to avoid feeling stuck)
					delay = TimeSpan.FromMilliseconds(Math.Min(delay.TotalMilliseconds * 1.5, 1000));
				}
			}

			throw new IOException("Timed out waiting to acquire the contacts file lock.");
		}
	}
}
